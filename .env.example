# ============================================
# FRONTEND (VITE_*) — bundled into the public JS.
# NEVER put secrets in VITE_ variables.
# ============================================

# Supabase (anon/publishable key is safe to expose; RLS is the guard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Strava (client ID is public; the secret is server-side only, below)
VITE_STRAVA_CLIENT_ID=
VITE_STRAVA_REDIRECT_URI=http://localhost:3000/auth/strava/callback

# Optional LLM configuration (OpenRouter)
VITE_LLM_PROVIDER=openrouter
VITE_LLM_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
VITE_LLM_MODEL=anthropic/claude-sonnet-4.5

# ============================================
# SERVER-SIDE ONLY — Vercel env vars / sync-runner.
# These must NOT have a VITE_ prefix.
# ============================================

# Supabase service role (admin access for sync + API routes)
# Get from: Supabase Dashboard -> Settings -> API -> service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE=your-service-role-key-here

# Protects /api/cron/sync — required, endpoint refuses requests without it
# Generate: openssl rand -hex 32
CRON_SECRET=

# Credential encryption key (AES-256-GCM), server-side ONLY.
# Generate: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# Strava OAuth secret (used by /api/strava/token)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Google Health API — successor of the Fitbit Web API (Fitbit/Pixel devices)
# Create OAuth client in Google Cloud Console; client ID is public (frontend),
# secret stays server-side.
VITE_GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=

# Garmin OAuth (used by /api/garmin/token)
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
