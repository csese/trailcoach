# Supabase Configuration
# Replace with your actual Supabase credentials
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Strava API Configuration
# Create an app at https://www.strava.com/settings/api
VITE_STRAVA_CLIENT_ID=
VITE_STRAVA_CLIENT_SECRET=
VITE_STRAVA_REDIRECT_URI=http://localhost:3000/auth/strava/callback

# Optional LLM configuration (OpenRouter)
VITE_LLM_PROVIDER=openrouter
VITE_LLM_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
VITE_LLM_API_KEY=
VITE_LLM_MODEL=anthropic/claude-sonnet-4.5

# ============================================
# BIOMETRICS SYNC CONFIGURATION
# ============================================
# These are used by the sync-runner.js script for daily background sync
# Add them to your .env.local or CI/CD environment

# Supabase Service Role (admin access for sync script)
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE=your-service-role-key-here

# Eight Sleep API (email/password auth)
EIGHT_SLEEP_EMAIL=
EIGHT_SLEEP_PASSWORD=

# Google Fit REST API (OAuth 2.0)
# Get refresh token from: https://developers.google.com/fit/rest/v1/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_FIT_REFRESH_TOKEN=

# Garmin Connect API
# Requires OAuth 1.0a credentials from Garmin Developer Portal
GARMIN_EMAIL=
GARMIN_PASSWORD=
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
